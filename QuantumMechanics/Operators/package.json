{
  "name": "qm-module-i1",
  "version": "1.0.0",
  "description": "QM/QC Programme \u2014 Module I.1: Hilbert Space & Operators \u2014 Lecture slide generator",
  "main": "src/generate_lectures.js",
  "scripts": {
